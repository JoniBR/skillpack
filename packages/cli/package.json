{
  "name": "@skill-pack/cli",
  "version": "0.2.0",
  "description": "Scaffold projects + agent skills in one command.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skillpack": "./dist/bin/skillpack.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "boilerplates/**/*",
    "meta-skills/**/*",
    "vendor/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/post-build.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(lint: no-op for v0.1)\"",
    "prepublishOnly": "node ./scripts/copy-bundled.mjs && pnpm build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
